generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model manager {
  id_            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lastname       String
  firstname      String
  middleInitial  String?
	email 				 String     @unique
  createdAt  		 DateTime   @default(now())
}

model route {
  id_                   String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid 
  name                  String     @unique @default(uuid())
  totalDistanceKm       Float
  totalDurationMinutes  Int
  vehicleType           String?
  createdAt             DateTime   @default(now())
  
  stops                 stop[]
  weekly_assignments    weekly_assignment[]
}

model stop {
  id_          String    @id @default(uuid())
  route_id_   String     @db.Uuid
  
  name        String
  address     String?
  lat         Float
  lng         Float
  order       Int                             // sequence in the route

  route       route     @relation(fields: [route_id_], references: [id_])

  @@index([route_id_]) 
}

// driver
model agent_profile {
  // Internal PK
  id_            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid 
  // External, from CORE user ID
  // agent_id_      String  @unique @db.Uuid 

  //employee_number
  driver_id      String  @unique @db.VarChar(100)
  contact_number String? @db.VarChar(100)
  license_number String? @db.VarChar(100)
  //avatar_url     String? @db.Text
  //tenant_id_     String  @db.Uuid

  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  //vehicles vehicle[]
  fuel_log            fuel_log[]
  weekly_assignments  weekly_assignment[]

  //@@index([agent_id_, tenant_id_])
  @@map("agent_profile")
  //@@schema("agents")
}

model weekly_assignment{
  id_             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  day_of_week     Int

  // Foreign Keys
  route_id_       String        @db.Uuid
  driver_id_      String        @db.Uuid 

  route           route         @relation(fields: [route_id_], references: [id_])
  agent_profile   agent_profile @relation(fields: [driver_id_], references: [id_])
  trips           trip[]

  @@unique([route_id_, driver_id_, day_of_week])
}

model trip {
  id_                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  status                  TripStatus @default(PENDING)
  tag_type                TagTypes   @default(OPEN)
  scheduled_date          DateTime?  @db.Timestamptz(6)
  notes                   String?    @db.Text
  image_url               String?    @db.Text
  proof_url               String?    @db.Text
  accepted_at             DateTime?  @db.Timestamptz(6)
  departed_at             DateTime?  @db.Timestamptz(6)
  completed_at            DateTime?  @db.Timestamptz(6)

  created_at              DateTime   @default(now()) @db.Timestamptz(6)
  updated_at              DateTime   @updatedAt @db.Timestamptz(6)
  deleted_at              DateTime?  @db.Timestamptz(6)

  // Foreign Keys
  weekly_assignment_id_   String?    @db.Uuid

  //vehicle_id_      String? @db.Uuid
  //assigned_by      String? @db.Uuid // FK to current user
  //task_purpose_id_ String? @db.Uuid
  //tenant_id_       String  @db.Uuid

  // Relations
  weekly_assignment       weekly_assignment? @relation(fields: [weekly_assignment_id_], references: [id_])
  orders                  order[]
            
  // vehicle       vehicle?       @relation(fields: [vehicle_id_], references: [id_])

  //trip_tasks trip_task[]
  //checkins   checkin[]

  // Indexes
  //@@unique([id_ , tenant_id_])
  // @@unique([id_])
  // @@index([created_at, updated_at, tenant_id_])
  // @@index([vehicle_id_, driver_id_, status, tag_type, tenant_id_])
  // @@map("trip")
  // @@schema("trips")

  @@index([weekly_assignment_id_])
  @@index([status])
  @@map("trip")
  //@@schema("trips")
}

model order_information {
  id_                String
  client             // not sure sa data type
  destination        String?
  order_date        DateTime
  agent_id_            String        (foreign)
  package_content    String
  package_size        String?        (written as int*int*int cm in UI)
  package_weight    Float
}

enum TripStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED

  //@@schema("trips")
}

enum OrderStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum TagTypes {
  OPEN
  ASSIGNED

  //@@schema("trips")
}